# Hanki ilmainen API-avain osoitteesta https://web3forms.com
VITE_WEB3FORMS_KEY=korvaa_tama_oikealla_avaimella

# Supabase — hae supabase.com > Project Settings > API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# Stripe — julkinen avain (turvallinen frontendissä)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_

# Salli julkinen Pro-demo (mock-vastauksilla). Oletus pois.
VITE_ALLOW_DEMO=false

# ---------------------------------------------------------------------------
# Seuraavat asetetaan VAIN Supabase-dashboardissa (Edge Functions > Secrets).
# ÄLÄ lisää näitä .env.local-tiedostoon — ne ovat vain palvelinpuolella!
#
# OPENAI_API_KEY=sk-...
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...
# ---------------------------------------------------------------------------
